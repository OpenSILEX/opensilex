<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.yvan.extension.org#"
     xml:base="http://www.yvan.extension.org"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:oeev="http://www.opensilex.org/vocabulary/oeev#"
     xmlns:oeso="http://www.opensilex.org/vocabulary/oeso#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:time="http://www.w3.org/2006/time#">
    <owl:Ontology rdf:about="http://www.yvan.extension.org">
        <dc:creator>yvan</dc:creator>
        <rdfs:comment>actually just a test to extend the opensilex core ontology in an opensilex test module</rdfs:comment>
        <rdfs:label xml:lang="en">OpenSILEX - Yvan onto</rdfs:label>
        <owl:versionInfo>Version 1.0</owl:versionInfo>
    </owl:Ontology>


    <owl:Class rdf:about="http://www.yvan.extension.org#SpiderMutagen">
        <rdfs:subClassOf rdf:resource="http://www.opensilex.org/vocabulary/oeso#ScientificObject"/>
        <rdfs:label xml:lang="en">Spider mutagen</rdfs:label>
        <rdfs:label xml:lang="fr">Mutagène d'araignée</rdfs:label>
    </owl:Class>

    <owl:ObjectProperty rdf:about="http://www.yvan.extension.org#hasExperiment">
        <rdfs:domain rdf:resource="http://www.yvan.extension.org#SpiderMutagen"/>
        <rdfs:range rdf:resource="http://www.opensilex.org/vocabulary/oeso#Experiment"/>
        <rdfs:label xml:lang="en">has experiment</rdfs:label>
        <rdfs:label xml:lang="fr">à une expérimentation</rdfs:label>
    </owl:ObjectProperty>


<!--      adding restrictions -->

    <owl:Class rdf:about="http://www.yvan.extension.org#SpiderMutagen">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.yvan.extension.org#hasExperiment"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.opensilex.org/vocabulary/oeso#Experiment"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

</rdf:RDF>
