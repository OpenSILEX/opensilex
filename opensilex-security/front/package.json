{
    "name": "opensilex-security",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "serve": "npx vite serve --config vite.config.ts",
        "build": "vite build --config vite.config.ts",
        "lint": "vite lint",
        "check:browserlist": "npm add caniuse-lite && npm remove caniuse-lite",
        "check:outdated": "npm outdated || cd .",
        "check:security": "npm audit || cd ."
    },
    "devDependencies": { 
        "@types/node": "20"
    },
    "eslintConfig": {
        "root": true,
        "env": {
            "node": true
        },
        "extends": [
            "plugin:vue/essential",
            "eslint:recommended",
            "@vue/typescript"
        ],
        "rules": {
            "no-unused-vars": "off",
            "no-var": "off",
            "prefer-const": "off",
            "vue/custom-event-name-casing": "off",
            "vue/no-unused-vars": "off"
        },
        "parserOptions": {
            "parser": "@typescript-eslint/parser"
        }
    },
    "browserslist": [
        "> 1%",
        "last 2 versions"
    ],
    "dependencies": {
        "@achrinza/node-ipc": "^10.1.11"
    }
}
