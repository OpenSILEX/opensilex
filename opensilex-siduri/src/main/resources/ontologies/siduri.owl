    <!-- http://www.opensilex.org/vocabulary/oeso#EuropeanOrganization -->

    <owl:Class rdf:about="http://www.opensilex.org/vocabulary/oeso#EuropeanOrganization">
        <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Organization"/>
        <rdfs:label xml:lang="en">european organization</rdfs:label>
        <rdfs:label xml:lang="fr">organisation européenne</rdfs:label>
    </owl:Class>
    


    <!-- http://www.opensilex.org/vocabulary/oeso#LocalOrganization -->

    <owl:Class rdf:about="http://www.opensilex.org/vocabulary/oeso#LocalOrganization">
        <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Organization"/>
        <rdfs:comment xml:lang="en">A LOCAL ORGANIZATION is a group of installations located in one site depending on one institution (or more), which share governance committees, a common (or at least highly interoperable) information system, common principles for cost calculation and pricing and a common tool for user access.</rdfs:comment>
        <rdfs:label xml:lang="en">local organization</rdfs:label>
        <rdfs:label xml:lang="fr">organisation locale</rdfs:label>
    </owl:Class>
    


    <!-- http://www.opensilex.org/vocabulary/oeso#NationalOrganization -->

    <owl:Class rdf:about="http://www.opensilex.org/vocabulary/oeso#NationalOrganization">
        <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Organization"/>
        <rdfs:comment xml:lang="en">A NATIONAL ORGANIZATION is an organized group of local organizations with governance recognised by national authorities (e.g. respective ministry or national structures).</rdfs:comment>
        <rdfs:label xml:lang="en">national organization</rdfs:label>
        <rdfs:label xml:lang="fr">organisation nationale</rdfs:label>
    </owl:Class>
    


    <!-- http://opendata.inrae.fr/ofs#JointResearchUnit -->

    <owl:Class rdf:about="http://opendata.inrae.fr/ofs#JointResearchUnit">
        <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Organization"/>
        <dc:source>skos:exactMatch http://opendata.inrae.fr/thesaurusINRAE/c_21443</dc:source>
        <rdfs:comment xml:lang="fr">Unité de recherche dont la tutelle est partagée avec un ou plusieurs autres partenaires académiques, organismes nationaux de recherche (ONR) et/ou universités et/ou grandes écoles.</rdfs:comment>
        <rdfs:label xml:lang="en">joint research unit </rdfs:label>
        <rdfs:label xml:lang="fr">unité mixte de recherche</rdfs:label>
    </owl:Class>
    


    <!-- http://opendata.inrae.fr/ofs#ServiceUnit -->

    <owl:Class rdf:about="http://opendata.inrae.fr/ofs#ServiceUnit">
        <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Organization"/>
        <dc:source>skos:exactMatch http://opendata.inrae.fr/thesaurusINRAE/c_2ab0c24d</dc:source>
        <rdfs:comment xml:lang="fr"> Structure dont les activités sont principalement dédiées à des offres de services et de ressources technologiques.</rdfs:comment>
        <rdfs:label xml:lang="en">service unit</rdfs:label>
        <rdfs:label xml:lang="fr">unité de service </rdfs:label>
    </owl:Class>
    


    <!-- http://xmlns.com/foaf/0.1/Organization -->

    <owl:Class rdf:about="http://xmlns.com/foaf/0.1/Organization"/>

    <!-- http://edamontology.org/data_2600 -->

    <owl:Class rdf:about="http://edamontology.org/data_2600">
        <rdfs:subClassOf rdf:resource="http://www.opensilex.org/vocabulary/oeso#Datafile"/>
        <rdfs:comment xml:lang="en">Primary data about a specific biological pathway or network (the nodes and connections within the pathway or network).</rdfs:comment>
        <rdfs:label xml:lang="en">Pathway or network</rdfs:label>
        <rdfs:label xml:lang="fr">Voie ou réseau biologique</rdfs:label>
    </owl:Class>

    


