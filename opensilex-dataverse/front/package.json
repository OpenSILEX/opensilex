{
    "name": "opensilex-dataverse",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "serve": "vite serve",
        "build": "vite build --config vite.config.ts",
        "lint": "vue-cli-service lint",
        "check:browserlist": "bun add caniuse-lite && bun remove caniuse-lite",
        "check:outdated": "bun outdated || cd .",
        "check:security": "bun audit || cd ."
    },
    "dependencies": {
        "@kazupon/vue-i18n-loader": "0.5.0",
        "vue-markdown-loader": "^2.5.0",
        "vue-i18n": "8.24.5"
    },
    "devDependencies": {
        
        "@vue/cli-plugin-eslint": "5.0.8",
        "@vue/cli-plugin-router": "5.0.8",
        
        "@vue/cli-plugin-vuex": "5.0.8",
        "@vue/cli-service": "5.0.8",
        "@vue/eslint-config-typescript": "7.0.0",
        "yaml-loader": "^0.6.0"
    },
    "eslintConfig": {
        "root": true,
        "env": {
            "node": true
        },
        "extends": [
            "plugin:vue/essential",
            "eslint:recommended",
            "@vue/typescript"
        ],
        "rules": {
            "no-unused-vars": "off",
            "no-var": "off",
            "prefer-const": "off",
            "vue/custom-event-name-casing": "off",
            "vue/no-unused-vars": "off"
        },
        "parserOptions": {
            "parser": "@typescript-eslint/parser"
        }
    },
    "browserslist": [
        "> 1%",
        "last 2 versions"
    ]
}
