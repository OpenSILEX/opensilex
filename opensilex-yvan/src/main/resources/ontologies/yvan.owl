<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.yvan.extension.org#"
     xml:base="http://www.yvan.extension.org"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:oeev="http://www.opensilex.org/vocabulary/oeev#"
     xmlns:oeso="http://www.opensilex.org/vocabulary/oeso#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:time="http://www.w3.org/2006/time#">
    <owl:Ontology rdf:about="http://www.yvan.extension.org">
        <dc:creator>yvan</dc:creator>
        <rdfs:comment>actually just a test to extend the opensilex core ontology in an opensilex test module</rdfs:comment>
        <rdfs:label xml:lang="en">OpenSILEX - Yvan onto</rdfs:label>
        <owl:versionInfo>Version 1.0</owl:versionInfo>
    </owl:Ontology>


    <owl:DatatypeProperty rdf:about="http://www.yvan.extension.org#legsNumber">
        <rdfs:domain rdf:resource="http://www.yvan.extension.org#SpiderMutagen"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="fr">nombre de pattes</rdfs:label>
        <rdfs:label xml:lang="en">number of legs</rdfs:label>
    </owl:DatatypeProperty>

    <owl:ObjectProperty rdf:about="http://www.yvan.extension.org#linkedDevice">
        <rdfs:domain rdf:resource="http://www.yvan.extension.org#SpiderMutagen"/>
        <rdfs:range rdf:resource="http://www.opensilex.org/vocabulary/oeso#Device"/>
        <rdfs:label xml:lang="en">linked device</rdfs:label>
        <rdfs:label xml:lang="fr">appareil lié</rdfs:label>
    </owl:ObjectProperty>



<!--   Spider mutagen -->

    <owl:Class rdf:about="http://www.yvan.extension.org#SpiderMutagen">
        <rdfs:subClassOf rdf:resource="http://www.opensilex.org/vocabulary/oeso#ScientificObject"/>
        <rdfs:label xml:lang="en">Spider mutagen</rdfs:label>
        <rdfs:label xml:lang="fr">Mutagène d'araignée</rdfs:label>
                <!--  data integer property defined in this ontology -->
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.yvan.extension.org#legsNumber"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
                <!--  device object property defined in this ontology with multiple cardinality -->
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.yvan.extension.org#linkedDevice"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">3</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.opensilex.org/vocabulary/oeso#Device"/>
            </owl:Restriction>
        </rdfs:subClassOf>
                <!-- lens (device) object property defined in the phis ontology -->
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.opensilex.org/vocabulary/oeso#hasLens"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.opensilex.org/vocabulary/oeso#Lens"/>
            </owl:Restriction>
        </rdfs:subClassOf>
                <!--   string data property defined in the phis ontology -->
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.opensilex.org/vocabulary/oeso#aperture"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

</rdf:RDF>
