    <!-- http://www.opensilex.org/vocabulary/oeso#hasAccession -->

    <owl:ObjectProperty rdf:about="http://www.opensilex.org/vocabulary/oeso#hasAccession">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.opensilex.org/vocabulary/oeso#Germplasm"/>
        <rdfs:range rdf:resource="http://www.opensilex.org/vocabulary/oeso#Accession"/>
        <rdfs:label xml:lang="fr">a une accession</rdfs:label>
        <rdfs:label xml:lang="en">has accession</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.opensilex.org/vocabulary/oeso-insect#hasBehaviour -->

    <owl:ObjectProperty rdf:about="http://www.opensilex.org/vocabulary/oeso-insect#hasBehaviour">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.opensilex.org/vocabulary/oeso-insect#MobileOrganism"/>
        <rdfs:range rdf:resource="http://www.opensilex.org/vocabulary/oeso-insect#Behaviour"/>
        <rdfs:label xml:lang="fr">a comportement</rdfs:label>
        <rdfs:label xml:lang="en">has behaviour</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.opensilex.org/vocabulary/oeso-insect#hasLine -->

