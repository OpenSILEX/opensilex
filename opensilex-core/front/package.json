{
    "name": "opensilex-core",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "license":"AGPL-3.0-only",
    "main": "./dist/mopensilex-core.umd.min.js",
    "module": "./dist/opensilex-core.umd.min.js",
    "exports": {
        ".": {
        "import": "./dist/opensilex-core.umd.min.js"
        }
    },
    "scripts": {
        "serve": "echo export interface ModelObject {} > src/lib/model/modelObject.ts && vite build --config vite.config.ts --watch",
        "build": "echo export interface ModelObject {} > src/lib/model/modelObject.ts && vite build --config vite.config.ts",
        "lint": "vue-cli-service lint",
        "check:browserlist": "npm add caniuse-lite && npm remove caniuse-lite",
        "check:outdated": "npm outdated || cd .",
        "check:security": "npm audit || cd ."
    },
    "devDependencies": {
         
        
    },
    "eslintConfig": {
        "root": true,
        "env": {
            "node": true
        },
        "extends": [
            "plugin:vue/essential",
            "eslint:recommended",
            "@vue/typescript"
        ],
        "rules": {
            "no-unused-vars": "off",
            "no-var": "off",
            "prefer-const": "off",
            "vue/custom-event-name-casing": "off",
            "vue/no-unused-vars": "off"
        },
        "parserOptions": {
            "parser": "@typescript-eslint/parser"
        }
    },
    "browserslist": [
        "> 1%",
        "last 2 versions"
    ],
    "dependencies": {}
}