<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.opensilex.org/vocabulary/oeso-insect#"
     xml:base="http://www.opensilex.org/vocabulary/oeso-insect"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:vocabulary="http://www.opensilex.org/vocabulary/oeso#"
     xmlns:webprotege="http://webprotege.stanford.edu/"
     xmlns:opensilex-api="http://www.opensilex.org/vocabulary/opensilex-api#">
    <owl:Ontology rdf:about="http://www.opensilex.org/vocabulary/oeso-insect">
        <dc:creator>Bernhard Gschloessl, Anne Tireau, Catherine Roussey, Pascal Neveu (INRAE Montpellier)</dc:creator>
        <rdfs:comment>INRAE MISTEA
            Copyright © - INRAE - 2014 - 2023
            Oeso extention ontology for INSECT is licensed by CC 4.0 (http://creativecommons.org/licenses/by-sa/4.0/legalcode)</rdfs:comment>
        <rdfs:label xml:lang="en">OpenSILEX - Insect</rdfs:label>
        <owl:versionInfo>Version 0.1 (2023-04-20) created by INRAE</owl:versionInfo>
    </owl:Ontology>
    


