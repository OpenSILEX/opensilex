        <rdfs:range rdf:resource="http://www.opensilex.org/vocabulary/oeso-insect#PhenotypicMeasurement"/>
        <rdfs:label xml:lang="fr">aMésure</rdfs:label>
        <rdfs:label xml:lang="en">hasMeasure</rdfs:label>
    </owl:ObjectProperty>
    


