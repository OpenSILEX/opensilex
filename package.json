{
    "name": "opensilex-vue-extension",
    "version": "0.1.0",
    "private": true,
    "license": "MIT",
    "scripts": {
        "serve": "vite serve",
        "build": "vite --base= lib src/index.ts",
        "lint": "vite lint",
        "check:browserlist": "npm add caniuse-lite && npm remove caniuse-lite",
        "check:outdated": "npm outdated || cd .",
        "check:security": "npm audit || cd .",
        "vite": "vite"
    },
    "dependencies": {
        "@fortawesome/fontawesome-svg-core": "^6.4.0",
        "@fortawesome/free-brands-svg-icons": "^6.4.0",
        "@fortawesome/free-regular-svg-icons": "^6.4.0",
        "@fortawesome/free-solid-svg-icons": "^6.4.0",
        "@vue/compat": "^3.5.13",
        "core-js": "3.6.5",
        "csv-string": "^4.0.1",
        "inversify": "^5.0.1",
        "node-fetch": "3.3.2",
        "npm-dts": "^1.3.13",
        "reflect-metadata": "0.1.13",
        "vee-validate": "4.15.0",
        "vue": "3.5.13",
        "vue-class-migrator": "^0.0.3",
        "vue-router": "3.4.9",
        "vue-tel-input": "5.3.0",
        "vuex": "4.1.0",
        "whatwg-fetch": "3.4.1"
    },
    "devDependencies": {
        "@types/node": "18",
        "@vitejs/plugin-vue": "^5.2.1",
        "@vue/compiler-sfc": "^3.5.13",
        "eslint": "^9.19.0",
        "eslint-plugin-vue": "^9.32.0",
        "sass": "1.83.4",
        "sass-loader": "16.0.4",
        "terser-webpack-plugin": "5.3.11",
        "typescript": "^5.5.4",
        "vite": "^6.0.11",
        "webpack": "^5.94.0"
    },
    "eslintConfig": {
        "root": true,
        "env": {
            "node": true
        },
        "extends": [
            "plugin:vue/essential",
            "eslint:recommended",
            "@vue/typescript"
        ],
        "rules": {
            "no-unused-vars": "off",
            "no-var": "off",
            "prefer-const": "off",
            "vue/custom-event-name-casing": "off",
            "vue/no-unused-vars": "off"
        },
        "parserOptions": {
            "parser": "@typescript-eslint/parser"
        }
    },
    "browserslist": [
        "> 1%",
        "last 2 versions"
    ]
}
