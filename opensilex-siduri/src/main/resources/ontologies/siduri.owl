    <!-- http://edamontology.org/data_2044 -->

    <owl:Class rdf:about="http://edamontology.org/data_2044">
        <rdfs:subClassOf rdf:resource="http://www.opensilex.org/vocabulary/oeso#Datafile"/>
        <rdfs:comment xml:lang="en">One or more molecular sequences, possibly with associated annotation.</rdfs:comment>
        <rdfs:label xml:lang="en">Sequence</rdfs:label>
        <rdfs:label xml:lang="fr">Séquence</rdfs:label>
    </owl:Class>
    


    <!-- http://edamontology.org/data_2048 -->

    <owl:Class rdf:about="http://edamontology.org/data_2048">
        <rdfs:subClassOf rdf:resource="http://www.opensilex.org/vocabulary/oeso#Datafile"/>
        <rdfs:comment xml:lang="en">A human-readable collection of information including annotation on a biological entity or phenomena, computer-generated reports of analysis of primary data (e.g. sequence or structural), and metadata (data about primary data) or any other free (essentially unformatted) text, as distinct from the primary data itself.</rdfs:comment>
        <rdfs:label xml:lang="fr">Rapport</rdfs:label>
        <rdfs:label xml:lang="en">Report</rdfs:label>
    </owl:Class>
    


    <!-- http://edamontology.org/data_2884 -->

    <owl:Class rdf:about="http://edamontology.org/data_2884">
        <rdfs:subClassOf rdf:resource="http://www.opensilex.org/vocabulary/oeso#Datafile"/>
        <rdfs:comment xml:lang="en">Biological data that has been plotted as a graph of some type, or plotting instructions for rendering such a graph.</rdfs:comment>
        <rdfs:label xml:lang="fr">Graphique</rdfs:label>
        <rdfs:label xml:lang="en">Plot</rdfs:label>
    </owl:Class>
    


    <!-- http://edamontology.org/data_2977 -->

    <owl:Class rdf:about="http://edamontology.org/data_2977">
        <rdfs:subClassOf rdf:resource="http://edamontology.org/data_2044"/>
        <rdfs:comment xml:lang="en">One or more nucleic acid sequences, possibly with associated annotation.</rdfs:comment>
        <rdfs:label xml:lang="en">Nucleic acid sequence</rdfs:label>
        <rdfs:label xml:lang="fr">Séquence d&apos;acide nucléique</rdfs:label>
    </owl:Class>
    


    <!-- http://edamontology.org/topic_0769 -->

    <owl:Class rdf:about="http://edamontology.org/topic_0769">
        <rdfs:subClassOf rdf:resource="http://www.opensilex.org/vocabulary/oeso#Device"/>
        <rdfs:comment xml:lang="en">Biological or biomedical analytical workflows or pipelines.</rdfs:comment>
        <rdfs:label>Workflow</rdfs:label>
    </owl:Class>
    


    <!-- http://www.opensilex.org/vocabulary/oeso#Datafile -->

