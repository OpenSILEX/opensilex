     xmlns:time="http://www.w3.org/2006/time#">
    <owl:Ontology rdf:about="http://www.opensilex.org/vocabulary/oeev-phis">
        <dc:creator>Anne Tireau, Llorenç Cabrera-Bosquet, Pascal Neveu (INRA Montpellier)</dc:creator>
