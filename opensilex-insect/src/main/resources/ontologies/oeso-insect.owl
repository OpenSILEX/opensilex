        <rdfs:range rdf:resource="http://www.opensilex.org/vocabulary/oeso-insect#Host"/>
        <rdfs:label xml:lang="fr">est parasite de</rdfs:label>
        <rdfs:label xml:lang="en">parasitises</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.opensilex.org/vocabulary/oeso-insect#studiedIn -->

