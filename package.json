{
    "name": "opensilex-vue-extension",
    "version": "0.1.0",
    "private": true,
    "license": "MIT",
    "scripts": {
        "serve": "vue-cli-service serve",
        "build": "export NODE_OPTIONS=--openssl-legacy-provider && vue-cli-service build --mode production --base= lib src/index.ts",
        "lint": "vue-cli-service lint",
        "check:browserlist": "bun add caniuse-lite && bun remove caniuse-lite",
        "check:outdated": "bun outdated || cd .",
        "check:security": "bun audit || cd .",
        "migrate": "vue-class-migrator migrate --directory opensilex-front/front/src/components/layout",
        "vite": "vite"
    },
    "dependencies": {
        "@fortawesome/fontawesome-svg-core": "^6.4.0",
        "@fortawesome/free-brands-svg-icons": "^6.4.0",
        "@fortawesome/free-regular-svg-icons": "^6.4.0",
        "@fortawesome/free-solid-svg-icons": "^6.4.0",
        "@vue/compat": "^3.4.38",
        "core-js": "3.6.5",
        "csv-string": "^4.0.1",
        "inversify": "^5.0.1",
        "node-fetch": "^2.6.0",
        "reflect-metadata": "0.1.13",
        "vee-validate": "4.15.0",
        "vue": "3.5.13",
        "vue-class-migrator": "^0.0.3",
        "vue-router": "3.4.9",
        "vue-tel-input": "5.3.0",
        "vuex": "4.1.0",
        "whatwg-fetch": "3.4.1"
    },
    "devDependencies": {
        "@types/node": "18",
        "@typescript-eslint/eslint-plugin": "8.23.0",
        "@typescript-eslint/parser": "8.23.0",
        "@vitejs/plugin-vue": "^5.2.1",
        "@vue/cli-plugin-eslint": "5.0.8",
        "@vue/cli-plugin-router": "5.0.8",
        "@vue/cli-plugin-vuex": "5.0.8",
        "@vue/cli-service": "5.0.8",
        "@vue/compiler-sfc": "^3.5.13",
        "@vue/eslint-config-typescript": "14.3.0",
        "bun-plugin-dts": "^0.3.0",
        "eslint-plugin-vue": "9.32.0",
        "sass": "1.83.4",
        "sass-loader": "16.0.4",
        "terser-webpack-plugin": "5.3.11",
        "typescript": "^5.5.4",
        "vite": "^6.0.11",
        "webpack": "^5.94.0"
    },
    "eslintConfig": {
        "root": true,
        "env": {
            "node": true
        },
        "extends": [
            "plugin:vue/essential",
            "eslint:recommended",
            "@vue/typescript"
        ],
        "rules": {
            "no-unused-vars": "off",
            "no-var": "off",
            "prefer-const": "off",
            "vue/custom-event-name-casing": "off",
            "vue/no-unused-vars": "off"
        },
        "parserOptions": {
            "parser": "@typescript-eslint/parser"
        }
    },
    "browserslist": [
        "> 1%",
        "last 2 versions"
    ]
}
