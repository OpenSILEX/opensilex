PREFIX vocabulary: <http://www.opensilex.org/vocabulary/oeso#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

<http://purl.obolibrary.org/obo/UO_1000027>  rdf:type  vocabulary:Unit    .
<http://purl.obolibrary.org/obo/UO_1000027>  rdfs:label  "degree Celsius"    .
<http://purl.obolibrary.org/obo/UO_1000027>  vocabulary:hasSymbol  "°C"    .
<http://purl.obolibrary.org/obo/UO_1000027>  rdfs:comment  "degree Celsius based unit"    .
<http://purl.obolibrary.org/obo/UO_1000027>  <http://www.w3.org/2004/02/skos/core#exactMatch>  "http://purl.obolibrary.org/obo/UO_1000027"    .
<http://purl.obolibrary.org/obo/UO_0000196>  rdf:type  vocabulary:Unit    .
<http://purl.obolibrary.org/obo/UO_0000196>  rdfs:label  "pH"    .
<http://purl.obolibrary.org/obo/UO_0000196>  rdfs:comment  "A dimensionless concentration notation which denotes the acidity of a solution in terms of activity of hydrogen ions (H+). [Wikipedia:Wikipedia]"    .
<http://purl.obolibrary.org/obo/UO_0000196>  <http://www.w3.org/2004/02/skos/core#exactMatch>  "http://purl.obolibrary.org/obo/UO_0000196"    .
<http://purl.obolibrary.org/obo/UO_0000173>  rdf:type  vocabulary:Unit    .
<http://purl.obolibrary.org/obo/UO_0000173>  rdfs:label  "gram per milliliter"    .
<http://purl.obolibrary.org/obo/UO_0000173>  vocabulary:hasSymbol "g/mL"    .
<http://purl.obolibrary.org/obo/UO_0000173>  vocabulary:hasAlternativeSymbol "g.mL-1"    .
<http://purl.obolibrary.org/obo/UO_0000173>  rdfs:comment  "A mass unit density which is equal to mass of an object in grams divided by the volume in milliliter. [UOC:GVG]"    .
<http://purl.obolibrary.org/obo/UO_0000173>  <http://www.w3.org/2004/02/skos/core#exactMatch>  "http://purl.obolibrary.org/obo/UO_0000173"    .
<http://purl.obolibrary.org/obo/UO_0000175>  rdf:type  vocabulary:Unit    .
<http://purl.obolibrary.org/obo/UO_0000175>  rdfs:label  "gram per liter"    .
<http://purl.obolibrary.org/obo/UO_0000175>  vocabulary:hasSymbol "g/L"    .
<http://purl.obolibrary.org/obo/UO_0000175>  vocabulary:hasAlternativeSymbol "g.L-1"    .
<http://purl.obolibrary.org/obo/UO_0000175>  rdfs:comment  "A mass unit density which is equal to mass of an object in grams divided by the volume in liters. [UOC:GVG]"    .
<http://purl.obolibrary.org/obo/UO_0000175>  <http://www.w3.org/2004/02/skos/core#exactMatch>  "http://purl.obolibrary.org/obo/UO_0000175"    .
<http://purl.obolibrary.org/obo/UO_0000088>  rdf:type  vocabulary:Unit    .
<http://purl.obolibrary.org/obo/UO_0000088>  rdfs:label  "gram per mole"    .
<http://purl.obolibrary.org/obo/UO_0000088>  vocabulary:hasSymbol "g/mol"    .
<http://purl.obolibrary.org/obo/UO_0000088>  vocabulary:hasAlternativeSymbol "g.mol-1"    .
<http://purl.obolibrary.org/obo/UO_0000088>  rdfs:comment  "A molar mass unit which is equal to one gram of mass of one mole of chemical element or chemical compound. [NIST:NIST]"    .
<http://purl.obolibrary.org/obo/UO_0000088>  <http://www.w3.org/2004/02/skos/core#exactMatch>  "http://purl.obolibrary.org/obo/UO_0000088"    .
