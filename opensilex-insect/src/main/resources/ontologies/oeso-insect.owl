    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/elements/1.1/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/source -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/source"/>
    


    <!-- http://www.w3.org/2002/07/owl#maxQualifiedCardinality -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2002/07/owl#maxQualifiedCardinality"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.opensilex.org/vocabulary/oeso-insect#hasLine -->

    <owl:ObjectProperty rdf:about="http://www.opensilex.org/vocabulary/oeso-insect#hasLine">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.opensilex.org/vocabulary/oeso-insect#Individual"/>
        <rdfs:range rdf:resource="http://www.opensilex.org/vocabulary/oeso-insect#Line"/>
        <rdfs:label xml:lang="fr">aLignée</rdfs:label>
        <rdfs:label xml:lang="en">hasLine</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.opensilex.org/vocabulary/oeso-insect#hasPart -->

    <owl:ObjectProperty rdf:about="http://www.opensilex.org/vocabulary/oeso-insect#hasPart">
        <rdfs:range rdf:resource="http://www.opensilex.org/vocabulary/oeso-insect#CameraComponent"/>
    </owl:ObjectProperty>
    


    <!-- http://www.opensilex.org/vocabulary/oeso-insect#hasSubLine -->

    <owl:ObjectProperty rdf:about="http://www.opensilex.org/vocabulary/oeso-insect#hasSubLine">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.opensilex.org/vocabulary/oeso-insect#Line"/>
        <rdfs:range rdf:resource="http://www.opensilex.org/vocabulary/oeso-insect#Subline"/>
        <rdfs:label xml:lang="fr">aSousLignée</rdfs:label>
        <rdfs:label xml:lang="en">hasSubLine</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.opensilex.org/vocabulary/oeso-insect#hasTracklet -->

    <owl:ObjectProperty rdf:about="http://www.opensilex.org/vocabulary/oeso-insect#hasTracklet">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.opensilex.org/vocabulary/oeso-insect#Individual"/>
        <rdfs:range rdf:resource="http://www.opensilex.org/vocabulary/oeso-insect#Tracklet"/>
    </owl:ObjectProperty>
    


    <!-- http://www.opensilex.org/vocabulary/oeso-insect#hasTrajectory -->

    <owl:ObjectProperty rdf:about="http://www.opensilex.org/vocabulary/oeso-insect#hasTrajectory">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.opensilex.org/vocabulary/oeso-insect#GroupOfIndividuals"/>
        <rdfs:range rdf:resource="http://www.opensilex.org/vocabulary/oeso-insect#Trajectory"/>
    </owl:ObjectProperty>
    


    <!-- http://www.opensilex.org/vocabulary/oeso-insect#isObservedIn -->

    <owl:ObjectProperty rdf:about="http://www.opensilex.org/vocabulary/oeso-insect#isObservedIn">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.opensilex.org/vocabulary/oeso#ScientificObject"/>
        <rdfs:range rdf:resource="http://www.opensilex.org/vocabulary/oeso#Facility"/>
        <rdfs:label xml:lang="en">observed in</rdfs:label>
        <rdfs:label xml:lang="fr">observé dans</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.opensilex.org/vocabulary/oeso-insect#isPartOf -->

    <owl:ObjectProperty rdf:about="http://www.opensilex.org/vocabulary/oeso-insect#isPartOf">
        <rdfs:domain rdf:resource="http://www.opensilex.org/vocabulary/oeso-insect#Individual"/>
        <rdfs:range rdf:resource="http://www.opensilex.org/vocabulary/oeso-insect#GroupOfIndividuals"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.opensilex.org/vocabulary/oeso-insect#birthday -->

    <owl:DatatypeProperty rdf:about="http://www.opensilex.org/vocabulary/oeso-insect#birthday">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.opensilex.org/vocabulary/oeso-insect#Individual"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:label xml:lang="fr">date de naissance</rdfs:label>
        <rdfs:label xml:lang="en">date of birth</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.opensilex.org/vocabulary/oeso-insect#hasLightIntensity -->

    <owl:DatatypeProperty rdf:about="http://www.opensilex.org/vocabulary/oeso-insect#hasLightIntensity">
        <rdfs:domain rdf:resource="http://www.opensilex.org/vocabulary/oeso-insect#Arena"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="fr">intensité de lumière</rdfs:label>
        <rdfs:label xml:lang="en">light intensity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.opensilex.org/vocabulary/oeso-insect#hasTemperature -->

    <owl:DatatypeProperty rdf:about="http://www.opensilex.org/vocabulary/oeso-insect#hasTemperature">
        <rdfs:domain rdf:resource="http://www.opensilex.org/vocabulary/oeso#Facility"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="en">temperature</rdfs:label>
        <rdfs:label xml:lang="fr">température</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.opensilex.org/vocabulary/oeso-insect#lineName -->

    <owl:DatatypeProperty rdf:about="http://www.opensilex.org/vocabulary/oeso-insect#lineName">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.opensilex.org/vocabulary/oeso-insect#Line"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">line name</rdfs:label>
        <rdfs:label xml:lang="fr">nom de la lignée</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.opensilex.org/vocabulary/oeso-insect#lineNumber -->

    <owl:DatatypeProperty rdf:about="http://www.opensilex.org/vocabulary/oeso-insect#lineNumber">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.opensilex.org/vocabulary/oeso-insect#Line"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="en">line number</rdfs:label>
        <rdfs:label xml:lang="fr">nombre de la lignée</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.opensilex.org/vocabulary/oeso-insect#lineType -->

    <owl:DatatypeProperty rdf:about="http://www.opensilex.org/vocabulary/oeso-insect#lineType">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.opensilex.org/vocabulary/oeso-insect#Line"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">line type</rdfs:label>
        <rdfs:label xml:lang="fr">type de la lignée</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://http://www.opensilex.org/vocabulary/oeso-insect#DisplayScreen -->

    <owl:Class rdf:about="http://http://www.opensilex.org/vocabulary/oeso-insect#DisplayScreen">
        <rdfs:subClassOf rdf:resource="http://www.opensilex.org/vocabulary/oeso#Lightning"/>
        <rdfs:label xml:lang="en">DisplayScreen</rdfs:label>
        <rdfs:label xml:lang="fr">Écran numérique</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.org/dc/dcmitype/Image -->

    <owl:Class rdf:about="http://purl.org/dc/dcmitype/Image">
        <rdfs:subClassOf rdf:resource="http://www.opensilex.org/vocabulary/oeso#Document"/>
        <rdfs:comment xml:lang="en">Examples include paintings, drawings, graphic designs, plans and maps. Recommended best practice is to assign the type Text to images of textual materials. Instances of the type Still Image must also be describable as instances of the broader type Image.</rdfs:comment>
        <rdfs:label xml:lang="en">Image</rdfs:label>
        <rdfs:label xml:lang="fr">Image</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.org/dc/dcmitype/MovingImage -->

    <owl:Class rdf:about="http://purl.org/dc/dcmitype/MovingImage">
        <rdfs:subClassOf rdf:resource="http://purl.org/dc/dcmitype/Image"/>
        <rdfs:comment xml:lang="en">Examples include animations, movies, television programs, videos, zoetropes, or visual output from a simulation. Instances of the type Moving Image must also be describable as instances of the broader type Image.</rdfs:comment>
        <rdfs:label xml:lang="fr">Image animée</rdfs:label>
        <rdfs:label xml:lang="en">Moving image</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.org/dc/dcmitype/Software -->

    <owl:Class rdf:about="http://purl.org/dc/dcmitype/Software">
        <rdfs:subClassOf rdf:resource="http://www.opensilex.org/vocabulary/oeso#Document"/>
        <rdfs:comment xml:lang="en">A computer program in source or compiled form.</rdfs:comment>
        <rdfs:label xml:lang="fr">Logiciel</rdfs:label>
        <rdfs:label xml:lang="en">Software</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.org/dc/dcmitype/StillImage -->

    <owl:Class rdf:about="http://purl.org/dc/dcmitype/StillImage">
        <rdfs:subClassOf rdf:resource="http://purl.org/dc/dcmitype/Image"/>
        <rdfs:comment xml:lang="en">Examples include paintings, drawings, graphic designs, plans and maps. Recommended best practice is to assign the type Text to images of textual materials. Instances of the type Still Image must also be describable as instances of the broader type Image.</rdfs:comment>
        <rdfs:label xml:lang="fr">Image fixe</rdfs:label>
        <rdfs:label xml:lang="en">Still image</rdfs:label>
    </owl:Class>
    


    <!-- http://www.opensilex.org/vocabulary/oeev#Event -->

    <owl:Class rdf:about="http://www.opensilex.org/vocabulary/oeev#Event">
        <rdfs:comment xml:lang="en">Event linked to an object involved in an experiment</rdfs:comment>
        <rdfs:comment xml:lang="fr">Événement lié a un objet</rdfs:comment>
        <rdfs:label xml:lang="en">Event</rdfs:label>
        <rdfs:label xml:lang="fr">Événement</rdfs:label>
    </owl:Class>


    <!-- http://www.opensilex.org/vocabulary/oeso-insect#Sampling -->

    <owl:Class rdf:about="http://www.opensilex.org/vocabulary/oeso-insect#Sampling">
        <rdfs:subClassOf rdf:resource="http://www.opensilex.org/vocabulary/oeev#ScientificObjectManagement"/>
        <rdfs:label xml:lang="fr">Échantillonnage</rdfs:label>
        <rdfs:label xml:lang="en">Sampling</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://purl.org/dc/dcmitype/StillImage">
        <rdfs:subClassOf rdf:resource="http://purl.org/dc/dcmitype/Image"/>
        <rdfs:comment xml:lang="en">Examples include paintings, drawings, graphic designs, plans and maps. Recommended best practice is to assign the type Text to images of textual materials. Instances of the type Still Image must also be describable as instances of the broader type Image.</rdfs:comment>
        <rdfs:label xml:lang="fr">Image fixe</rdfs:label>
        <rdfs:label xml:lang="en">Still image</rdfs:label>
    </owl:Class>


    <!-- http://www.opensilex.org/vocabulary/oeev#Incident -->

    <owl:Class rdf:about="http://www.opensilex.org/vocabulary/oeev#Incident">
        <rdfs:subClassOf rdf:resource="http://www.opensilex.org/vocabulary/oeev#Trouble"/>
        <rdfs:comment xml:lang="fr">Agit sur un objet scientifique</rdfs:comment>
        <rdfs:comment xml:lang="en">Concerns a scientific object</rdfs:comment>
        <rdfs:label xml:lang="en">Incident</rdfs:label>
        <rdfs:label xml:lang="fr">Incident</rdfs:label>
    </owl:Class>


    <!-- http://www.opensilex.org/vocabulary/oeso-insect#ObservedPhenology -->

    <owl:Class rdf:about="http://www.opensilex.org/vocabulary/oeso-insect#ObservedPhenology">
        <rdfs:subClassOf rdf:resource="http://www.opensilex.org/vocabulary/oeev#ScientificObjectManagement"/>
        <rdfs:label xml:lang="fr">Phénologie observée</rdfs:label>
        <rdfs:label xml:lang="en">Observed phenology</rdfs:label>
    </owl:Class>


    <!-- http://www.opensilex.org/vocabulary/oeev#ScientificObjectManagement -->

    <owl:Class rdf:about="http://www.opensilex.org/vocabulary/oeev#ScientificObjectManagement">
        <rdfs:subClassOf rdf:resource="http://www.opensilex.org/vocabulary/oeev#Event"/>
        <rdfs:label xml:lang="fr">Gestion d&apos;objet scientifique</rdfs:label>
        <rdfs:label xml:lang="en">Scientific object management</rdfs:label>
    </owl:Class>


    <!-- http://www.opensilex.org/vocabulary/oeso-insect#Treatment -->

    <owl:Class rdf:about="http://www.opensilex.org/vocabulary/oeso-insect#Treatment">
        <rdfs:subClassOf rdf:resource="http://www.opensilex.org/vocabulary/oeev#ScientificObjectManagement"/>
        <rdfs:label xml:lang="fr">Traitement</rdfs:label>
        <rdfs:label xml:lang="en">Treatment</rdfs:label>
    </owl:Class>


    <!-- http://www.opensilex.org/vocabulary/oeev#Event -->

   <owl:Class rdf:about="http://www.opensilex.org/vocabulary/oeev#Event">
