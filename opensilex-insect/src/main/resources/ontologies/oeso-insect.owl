        <rdfs:label xml:lang="en">observed in</rdfs:label>
        <rdfs:label xml:lang="fr">observé dans</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.opensilex.org/vocabulary/oeso-insect#parasitisesEgg -->

    <owl:ObjectProperty rdf:about="http://www.opensilex.org/vocabulary/oeso-insect#parasitisesEgg">
